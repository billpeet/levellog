{
	"name": "levellog",
	"private": true,
	"version": "0.0.1",
	"packageManager": "bun@1.3.9",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"lint": "eslint .",
